{
  "name": "@sofa/tmdb",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./client": "./src/client.ts",
    "./image": "./src/image.ts"
  },
  "scripts": {
    "lint": "biome check",
    "format": "biome format --write",
    "check-types": "tsc --noEmit",
    "generate-schema": "bunx openapi-typescript https://developer.themoviedb.org/openapi/tmdb-api.json -o ./src/schema.d.ts"
  },
  "dependencies": {
    "@sofa/db": "workspace:*",
    "openapi-fetch": "0.17.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.10",
    "typescript": "5.9.3"
  }
}
