{
  "name": "sofa-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "bun --bun next build",
    "dev": "bun --bun next dev",
    "start": "bun --bun next start",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check-types": "bun --bun fumadocs-mdx && bun --bun next typegen && tsc --noEmit",
    "generate:api-docs": "bun scripts/generate-api-docs.ts",
    "postinstall": "bun --bun fumadocs-mdx"
  },
  "dependencies": {
    "@takumi-rs/image-response": "^1.8.7",
    "@vercel/analytics": "^2.0.1",
    "fumadocs-core": "^16.10.7",
    "fumadocs-mdx": "^15.0.13",
    "fumadocs-openapi": "^11.0.6",
    "fumadocs-ui": "^16.10.7",
    "lucide-react": "^0.577.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shiki": "^4.3.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/bun": "1.3.14",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3"
  },
  "packageManager": "bun@1.3.14"
}
