    "@sofa/api": "workspace:*",
    "@sofa/auth": "workspace:*",
    "@sofa/config": "workspace:*",
    "@sofa/core": "workspace:*",
    "@sofa/db": "workspace:*",
    "@sofa/logger": "workspace:*",
    "@sofa/tmdb": "workspace:*",
    "croner": "10.0.2-dev.2",
    "hono": "4.12.8",
    "zod": "catalog:"
