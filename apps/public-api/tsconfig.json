{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["esnext"],
    "strict": true,
    "noEmit": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "skipLibCheck": true,
    "types": ["bun"]
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
