{
  "name": "@sofa/public-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "PORT=3002 bun --watch src/app.ts",
    "start": "PORT=3002 bun src/app.ts",
    "lint": "oxlint",
    "format": "oxfmt --config ../../.oxfmtrc.json",
